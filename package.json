{
	"name": "react-render-kit",
	"private": true,
	"version": "0.0.0",
	"workspaces": [
		"packages/*",
		"demo"
	],
	"scripts": {
		"build": "pnpm --filter @sapanmozammel/why-render build && pnpm --filter demo build",
		"dev": "pnpm --filter @sapanmozammel/why-render build && pnpm --filter demo dev",
		"test": "pnpm -r test",
		"test:watch": "pnpm -r test:watch",
		"test:coverage": "pnpm -r test:coverage",
		"test:e2e": "pnpm exec playwright test",
		"lint": "eslint packages/*/src packages/*/tests",
		"lint:fix": "eslint --fix packages/*/src packages/*/tests",
		"format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\" \"*.{json,md,yaml}\"",
		"format:all": "pnpm run format && pnpm run lint:fix",
		"type:check": "pnpm -r exec tsc --noEmit",
		"sync": "node .formatter/sync.js"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@playwright/test": "^1.60.0",
		"@types/node": "^22.0.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.0",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.0",
		"eslint-plugin-react": "^7.37.0",
		"eslint-plugin-react-hooks": "^5.1.0",
		"eslint-plugin-unicorn": "^56.0.0",
		"prettier": "^3.4.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3"
	}
}
