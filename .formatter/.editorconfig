root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,jsx,ts,tsx}]
indent_style = tab
indent_size = 4
max_line_length = 220

[*.{css,scss,less,json,jsonc}]
indent_style = tab
indent_size = 4

[*.{yml,yaml,md,mdx}]
indent_style = space
indent_size = 2

[package.json]
indent_style = space
indent_size = 2